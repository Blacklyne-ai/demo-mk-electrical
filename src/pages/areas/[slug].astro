---
import Layout from '../../layouts/Layout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import ReviewCard from '../../components/ReviewCard.astro';
import CtaBand from '../../components/CtaBand.astro';
import Icon from '../../components/Icon.astro';
import { areaPages, areaTemplate as T } from '../../data/areas';
import { featuredReviews } from '../../data/reviews';
import { site, telLink } from '../../data/site';

export function getStaticPaths() {
  return areaPages.map((a) => ({ params: { slug: a.slug }, props: { area: a } }));
}

const { area } = Astro.props;
const a = area.name;
const otherAreas = areaPages.filter((x) => x.slug !== area.slug);
---

<Layout
  current={`/areas/${area.slug}`}
  title={`Electrician in ${a} | MK Electrical London — Family-run Since 1994`}
  description={`Looking for an electrician in ${a}? MK Electrical London brings over 20 years of electrical expertise to your ${a} doorstep. EICRs, rewiring, EV chargers, emergency repairs.`}
>
  <!-- Area-Hero mit Original-Bild der alten Site -->
  <section class="relative overflow-hidden pt-32 pb-20 md:pt-44 md:pb-28 bg-ink-deep">
    <img
      src={area.image}
      srcset={`${area.image.replace(/\.jpg$/, '-480.jpg')} 480w, ${area.image.replace(/\.jpg$/, '-800.jpg')} 800w, ${area.image} 1400w`}
      sizes="100vw"
      alt={`${a}, London`}
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 hero-overlay" aria-hidden="true"></div>

    <div class="container-mk relative z-10">
      <nav class="flex items-center gap-2 text-[0.78rem] text-white/55 mb-7 fade-in" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition">Home</a>
        <Icon name="ChevronRight" size={13} strokeWidth={2.4} />
        <span class="text-white/85 font-medium">{a}</span>
      </nav>
      <span class="eyebrow eyebrow-light mb-5 fade-in">Electrician in {a}</span>
      <h1 class="heading-xl text-white hero-text-shadow text-balance max-w-3xl fade-in stagger-1">
        {T.heroQuestion(a)} <em class="accent-serif">You’ve found the right team.</em>
      </h1>
      <p class="text-lg md:text-xl text-white/85 hero-text-shadow leading-relaxed max-w-2xl mt-6 text-pretty fade-in stagger-2">
        MK Electrical London brings over 20 years of electrical expertise directly to your {a} doorstep.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 mt-9 fade-in stagger-3">
        <a href="/contact" class="btn btn-light btn-lg">
          Book now
          <Icon name="ArrowRight" size={16} strokeWidth={2.5} />
        </a>
        <a href={telLink} class="btn btn-glass btn-lg">
          <Icon name="Phone" size={17} strokeWidth={2.3} />
          {site.phone}
        </a>
      </div>
      <div class="trust-strip text-white/65 mt-10 fade-in stagger-4">
        <span>Since 1994</span>
        <span>5,000+ happy customers</span>
        <span>NICEIC Approved</span>
        <span>Family-run</span>
      </div>
    </div>
  </section>

  <!-- Warum (verbatim) -->
  <section class="bg-white py-24 md:py-28">
    <div class="container-mk">
      <div class="grid lg:grid-cols-12 gap-12">
        <div class="lg:col-span-7 fade-in">
          <span class="eyebrow mb-5">Why {a}?</span>
          <h2 class="heading-lg text-balance mb-7">Why {a} residents choose <em class="accent-serif">MK Electrical London.</em></h2>
          <p class="text-muted leading-relaxed text-[1.05rem] max-w-2xl">{T.whyBody(a)}</p>
          <p class="text-muted leading-relaxed text-[1.05rem] max-w-2xl mt-4">{T.propertyBody}</p>
        </div>
        <div class="lg:col-span-5 fade-in stagger-1">
          <div class="card !p-7">
            <p class="text-[0.7rem] font-mono font-semibold uppercase tracking-[0.18em] text-muted mb-5">{T.differenceTitle}</p>
            <ul class="space-y-4">
              {T.difference.map((d) => (
                <li class="flex items-start gap-3">
                  <span class="w-6 h-6 rounded-full bg-ink text-white inline-flex items-center justify-center flex-shrink-0 mt-0.5">
                    <Icon name="Check" size={13} strokeWidth={3} />
                  </span>
                  <div>
                    <p class="font-display font-bold text-ink text-[0.95rem]">{d.title}</p>
                    <p class="text-muted text-[0.88rem] leading-snug mt-0.5">{typeof d.body === 'function' ? d.body(a) : d.body}</p>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Komplette Services in [AREA] (verbatim Gruppen) -->
  <section class="section-paper py-24 md:py-28">
    <div class="container-mk">
      <SectionHeading
        eyebrow={`Services in ${a}`}
        title={`Our complete electrical services in <em>${a}.</em>`}
      />
      <div class="grid md:grid-cols-3 gap-5 md:gap-6 mt-12">
        {T.serviceGroups.map((g, i) => (
          <div class={`card-feature fade-in stagger-${i + 1}`}>
            <span class="inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-ink text-white mb-5">
              <Icon name={g.icon} size={22} strokeWidth={2} />
            </span>
            <h3 class="font-display font-bold text-lg text-ink mb-4 leading-snug">{g.title}</h3>
            <ul class="space-y-2.5">
              {g.items.map((item) => (
                <li class="flex items-start gap-2.5 text-[0.92rem] text-muted leading-snug">
                  <Icon name="ChevronRight" size={15} strokeWidth={2.4} class="text-ink mt-0.5 flex-shrink-0" />
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
      <p class="text-muted text-[0.95rem] mt-9 fade-in">
        {T.propertyTitle(a)} — see <a href="/services" class="underline underline-offset-2 hover:text-ink transition">all services</a> for the full list.
      </p>
    </div>
  </section>

  <!-- Reviews -->
  <section class="bg-white py-24 md:py-28">
    <div class="container-mk">
      <SectionHeading
        eyebrow="Nearby word of mouth"
        title="What neighbours <em>say.</em>"
        ctaHref="/reviews"
        ctaLabel="All reviews"
      />
      <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-5 md:gap-6 mt-12">
        {featuredReviews.map((r, i) => <ReviewCard review={r} stagger={(i % 4) + 1} />)}
      </div>
    </div>
  </section>

  <!-- Ready to get started (verbatim) + andere Areas -->
  <section class="section-paper py-24 md:py-28">
    <div class="container-mk">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="fade-in">
          <span class="eyebrow mb-5">{T.readyTitle}</span>
          <h2 class="heading-lg text-balance mb-6">Don’t let electrical issues disrupt your <em class="accent-serif">{a} property.</em></h2>
          <p class="text-muted leading-relaxed text-pretty">{T.readyBody(a)} {T.readyCta(a)}</p>
          <div class="flex flex-col sm:flex-row gap-3 mt-8">
            <a href="/contact" class="btn btn-ink btn-lg">
              Book your free consultation
              <Icon name="ArrowRight" size={16} strokeWidth={2.5} />
            </a>
          </div>
        </div>
        <div class="fade-in stagger-1">
          <p class="text-[0.7rem] font-mono font-semibold uppercase tracking-[0.18em] text-muted mb-4">Also covering</p>
          <div class="flex flex-wrap gap-2.5">
            {otherAreas.map((o) => (
              <a href={`/areas/${o.slug}`} class="tag">
                <Icon name="MapPin" size={14} strokeWidth={2} class="text-muted" />
                {o.name}
              </a>
            ))}
            <span class="tag !bg-paper text-muted">Putney</span>
            <span class="tag !bg-paper text-muted">Barnes</span>
          </div>
          <p class="text-muted-light text-[0.88rem] mt-4">{site.serviceAreaNote}.</p>
        </div>
      </div>
    </div>
  </section>

  <CtaBand />
</Layout>
