---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import ReviewCard from '../../components/ReviewCard.astro';
import CtaBand from '../../components/CtaBand.astro';
import Icon from '../../components/Icon.astro';
import { services } from '../../data/services';
import { reviews } from '../../data/reviews';
import { telLink, site } from '../../data/site';

export function getStaticPaths() {
  return services.map((s) => ({ params: { slug: s.slug }, props: { service: s } }));
}

const { service } = Astro.props;

// Akzent: letzte zwei Wörter der Hero-Line in Fraunces Italic
const words = service.heroLine.split(' ');
const cut = Math.max(words.length - 2, 1);
const heroTitle = `${words.slice(0, cut).join(' ')} <em>${words.slice(cut).join(' ')}</em>`;

const others = services.filter((s) => s.slug !== service.slug);

// Passende Reviews je Service (Stichwort-Matching auf echte Zitate)
const keywordMap: Record<string, string[]> = {
  'eicr-testing': ['inspection', 'report', 'wiring'],
  'pat-testing': ['professional', 'office'],
  rewiring: ['refurbishment', 'rewir', 'installation and upgrade'],
  'fuse-boards': ['fuse board', 'fuse box'],
  'ev-chargers': ['attention to detail', 'prepared'],
  'fault-finding': ['emergency', 'fault', 'gremlin', 'sockets'],
};
const kws = keywordMap[service.slug] ?? [];
const related = reviews
  .filter((r) => kws.some((k) => r.text.toLowerCase().includes(k)))
  .slice(0, 2);
const fallback = reviews.filter((r) => !related.includes(r)).slice(0, 2 - related.length);
const serviceReviews = [...related, ...fallback].slice(0, 2);
---

<Layout
  current={`/services/${service.slug}`}
  title={`${service.name} | MK Electrical London — South West London`}
  description={service.metaDescription}
>
  <PageHero
    crumb={service.name}
    eyebrow={`Services · ${service.name}`}
    title={heroTitle}
    subtitle={service.short}
    image={service.image}
    imageAlt={service.imageAlt}
    primary={{ href: '/contact', label: 'Get a free estimate' }}
    secondary={{ href: telLink, label: `Call ${site.phone}` }}
  />

  <!-- Intro -->
  <section class="bg-white py-24 md:py-28">
    <div class="container-mk">
      <div class="grid lg:grid-cols-12 gap-12">
        <div class="lg:col-span-7 fade-in">
          <span class="eyebrow mb-5">{service.name}</span>
          <h2 class="heading-lg text-balance mb-7">The straight <em class="accent-serif">version.</em></h2>
          <div class="space-y-4 text-muted leading-relaxed text-[1.05rem] max-w-2xl">
            {service.intro.map((p) => <p>{p}</p>)}
          </div>
        </div>
        <div class="lg:col-span-5 fade-in stagger-1">
          <div class="card !p-7 space-y-5">
            <p class="text-[0.7rem] font-mono font-semibold uppercase tracking-[0.18em] text-muted">Why MK for this job</p>
            <ul class="space-y-3.5">
              <li class="flex items-start gap-3">
                <Icon name="ShieldCheck" size={19} strokeWidth={2.1} class="text-ink mt-0.5 flex-shrink-0" />
                <span class="text-[0.95rem] text-muted"><strong class="text-ink font-semibold">NICEIC Approved Contractors</strong> and Part P registered</span>
              </li>
              <li class="flex items-start gap-3">
                <Icon name="Users" size={19} strokeWidth={2.1} class="text-ink mt-0.5 flex-shrink-0" />
                <span class="text-[0.95rem] text-muted"><strong class="text-ink font-semibold">Family-run since 1994</strong> — from Mario to Martin &amp; Laura</span>
              </li>
              <li class="flex items-start gap-3">
                <Icon name="Receipt" size={19} strokeWidth={2.1} class="text-ink mt-0.5 flex-shrink-0" />
                <span class="text-[0.95rem] text-muted"><strong class="text-ink font-semibold">Transparent pricing</strong> — scope, time and materials agreed up front</span>
              </li>
              <li class="flex items-start gap-3">
                <Icon name="MapPin" size={19} strokeWidth={2.1} class="text-ink mt-0.5 flex-shrink-0" />
                <span class="text-[0.95rem] text-muted"><strong class="text-ink font-semibold">Most London postcodes</strong> (excluding East London)</span>
              </li>
            </ul>
            <a href="/contact" class="btn btn-ink btn-block">
              Book now
              <Icon name="ArrowRight" size={15} strokeWidth={2.4} />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Leistungsumfang -->
  <section class="section-paper py-24 md:py-28">
    <div class="container-mk">
      <SectionHeading
        eyebrow="What’s covered"
        title={`${service.name} — <em>what you get.</em>`}
      />
      <div class="grid sm:grid-cols-2 gap-5 mt-12 max-w-4xl">
        {service.includes.map((inc, i) => (
          <div class={`card-feature !p-7 fade-in stagger-${(i % 2) + 1}`}>
            <span class="inline-flex items-center justify-center w-10 h-10 rounded-xl bg-ink text-white mb-4">
              <Icon name="Check" size={18} strokeWidth={2.6} />
            </span>
            <p class="font-display font-bold text-ink leading-snug">{inc.label}</p>
            {inc.detail && <p class="text-muted text-[0.9rem] mt-1.5 leading-relaxed">{inc.detail}</p>}
          </div>
        ))}
      </div>
    </div>
  </section>

  {service.knowBlocks && (
    <section class="bg-white py-24 md:py-28">
      <div class="container-mk">
        <SectionHeading eyebrow="Useful to know" title="Before you <em>book.</em>" />
        <div class="grid md:grid-cols-2 gap-6 mt-12 max-w-5xl">
          {service.knowBlocks.map((k, i) => (
            <div class={`card !p-8 fade-in stagger-${i + 1}`}>
              <h3 class="font-display font-bold text-ink text-lg mb-4">{k.title}</h3>
              <div class="space-y-3 text-muted text-[0.95rem] leading-relaxed">
                {k.paragraphs.map((p) => <p>{p}</p>)}
              </div>
              {k.list && (
                <ul class="mt-4 space-y-2.5">
                  {k.list.map((item) => (
                    <li class="flex items-start gap-2.5 text-[0.92rem] text-muted">
                      <Icon name="ChevronRight" size={15} strokeWidth={2.4} class="text-ink mt-1 flex-shrink-0" />
                      {item}
                    </li>
                  ))}
                </ul>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Reviews + andere Services -->
  <section class={`${service.knowBlocks ? 'section-paper' : 'bg-white'} py-24 md:py-28`}>
    <div class="container-mk">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
        <div class="fade-in">
          <span class="eyebrow mb-5">What customers say</span>
          <h2 class="heading-md mb-8">Heard around <em class="accent-serif">South West London.</em></h2>
          <div class="space-y-5">
            {serviceReviews.map((r) => <ReviewCard review={r} />)}
          </div>
        </div>
        <div class="fade-in stagger-1">
          <span class="eyebrow mb-5">Everything else we do</span>
          <h2 class="heading-md mb-8">One team for <em class="accent-serif">the whole job.</em></h2>
          <ul class="space-y-3">
            {others.map((o) => (
              <li>
                <a href={`/services/${o.slug}`} class="group flex items-center gap-4 bg-white border border-line rounded-2xl px-5 py-4 transition hover:border-ink/40 hover:shadow-lg">
                  <span class="inline-flex items-center justify-center w-10 h-10 rounded-xl bg-ink text-white flex-shrink-0">
                    <Icon name={o.icon} size={18} strokeWidth={2} />
                  </span>
                  <span class="font-display font-semibold text-ink flex-1">{o.name}</span>
                  <Icon name="ArrowRight" size={16} strokeWidth={2.2} class="text-muted-light transition group-hover:translate-x-1 group-hover:text-ink" />
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <CtaBand />
</Layout>
