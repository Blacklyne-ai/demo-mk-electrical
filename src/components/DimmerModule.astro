---
// DER DIMMER — interaktives Licht-Modul. Der Regler steuert die
// Helligkeit des echten Arbeitsfotos (Kirchen-Lichtinstallation).
// Reine Visualisierung über CSS-Variablen, kein Fake-Inhalt.
import Icon from './Icon.astro';
---
<div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
  <div class="fade-in">
    <span class="eyebrow mb-5">Lighting, made tangible</span>
    <h2 class="heading-lg text-balance mb-6">
      Good lighting changes everything. <em class="accent-serif">Try the dimmer.</em>
    </h2>
    <p class="text-muted text-lg leading-relaxed mb-8 text-pretty">
      From wireless lighting systems and spotlight upgrades to backlit installations like this one — light fitting replacements are on our everyday list. Drag the dimmer and watch a real MK installation come to life.
    </p>
    <div class="flex items-center gap-5 max-w-md">
      <Icon name="Lightbulb" size={22} strokeWidth={2} class="text-muted-light flex-shrink-0" />
      <input
        type="range"
        id="dimmer"
        class="dimmer-track"
        min="10"
        max="100"
        value="55"
        aria-label="Dim the lights on the photo"
      />
      <Icon name="Sparkles" size={22} strokeWidth={2} class="text-volt-deep flex-shrink-0" />
    </div>
    <p class="font-mono text-[0.68rem] uppercase tracking-[0.18em] text-muted-light mt-4">
      Output: <span id="dimmer-value" class="text-ink font-semibold">55</span>% · A real install, Fulham
    </p>
  </div>

  <div class="relative fade-in stagger-1">
    <div class="photo-frame photo-frame-dark bg-ink-deep" data-tilt="3">
      <img
        id="dimmer-photo"
        src="/images/work/church-lighting.jpg"
        srcset="/images/work/church-lighting-480.jpg 480w, /images/work/church-lighting-800.jpg 800w, /images/work/church-lighting.jpg 1100w"
        sizes="(min-width: 1024px) 44vw, 92vw"
        alt="Backlit cross installation by MK Electrical London — brightness controlled by the dimmer"
        width="1100"
        height="1467"
        class="w-full aspect-[4/5] object-cover"
        loading="lazy"
        style="filter: brightness(0.83) saturate(0.9); transition: filter 0.18s linear;"
      />
      <div
        id="dimmer-glow"
        class="absolute inset-0 pointer-events-none"
        style="background: radial-gradient(ellipse at 50% 42%, rgb(255 184 28 / 0.28), transparent 62%); opacity: 0.25; transition: opacity 0.18s linear;"
        aria-hidden="true"
      ></div>
    </div>
    <div class="card-glass card-glass-dark absolute -bottom-5 left-6 px-5 py-3.5 flex items-center gap-3">
      <span class="led" aria-hidden="true"></span>
      <p class="text-[0.68rem] font-mono font-semibold uppercase tracking-[0.14em]">Wireless lighting<br /><span class="text-white/55">resolved under warranty — Neil, SW15</span></p>
    </div>
  </div>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const dimmer = document.getElementById('dimmer') as HTMLInputElement | null;
    const photo = document.getElementById('dimmer-photo') as HTMLElement | null;
    const glow = document.getElementById('dimmer-glow') as HTMLElement | null;
    const value = document.getElementById('dimmer-value');
    if (!dimmer || !photo) return;
    const apply = () => {
      const v = parseInt(dimmer.value, 10);
      photo.style.filter = `brightness(${(0.42 + v * 0.0075).toFixed(3)}) saturate(${(0.65 + v * 0.0045).toFixed(3)})`;
      if (glow) glow.style.opacity = String((v / 100) * 0.85);
      if (value) value.textContent = String(v);
    };
    dimmer.addEventListener('input', apply);
    apply();
  });
</script>
