---
import { nav, telLink, site } from '../data/site';
import Icon from './Icon.astro';
const { current = '' } = Astro.props;

const isActive = (item: (typeof nav)[number]) =>
  current === item.href ||
  (item.href !== '/' && current.startsWith(item.href));
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50">
  <div class="container-mk pt-3 md:pt-5">
    <div
      id="nav-shell"
      class="flex items-center justify-between gap-3 pl-3 pr-2 md:pl-4 md:pr-2.5 py-2 rounded-pill transition-all duration-500"
      style="background: rgba(255,255,255,0.85); backdrop-filter: blur(20px) saturate(170%); -webkit-backdrop-filter: blur(20px) saturate(170%); border: 1px solid rgba(17,17,19,0.08); box-shadow: 0 1px 2px rgba(17,17,19,0.04), 0 8px 32px -8px rgba(17,17,19,0.14), inset 0 1px 0 0 rgba(255,255,255,0.7);"
    >
      <!-- Original-Logo (Wortmarke der alten Site, 1:1) -->
      <a href="/" class="flex items-center flex-shrink-0" aria-label="MK Electrical London — home">
        <img src="/logo.png" alt="MK Electrical London — Est. 1994" width="505" height="101" class="h-8 md:h-9 w-auto" />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-0.5" aria-label="Primary">
        {nav.map((item) =>
          item.children ? (
            <div class="nav-dd relative">
              <a href={item.href} class={`nav-pill inline-flex items-center gap-1 ${isActive(item) ? 'active' : ''}`} aria-haspopup="true" aria-expanded="false">
                {item.label}
                <Icon name="ChevronDown" size={14} strokeWidth={2.4} class="nav-dd-chev" />
              </a>
              <div class="nav-dd-panel" role="menu">
                {item.children.map((c) => (
                  <a href={c.href} role="menuitem" class={`nav-dd-item ${current === c.href ? 'active' : ''}`}>{c.label}</a>
                ))}
              </div>
            </div>
          ) : (
            <a href={item.href} class={`nav-pill ${isActive(item) ? 'active' : ''}`}>{item.label}</a>
          )
        )}
      </nav>

      <!-- Right cluster -->
      <div class="flex items-center gap-2">
        <a href={telLink} class="btn btn-outline btn-sm hidden xl:inline-flex" aria-label={`Call us on ${site.phone}`}>
          <Icon name="Phone" size={14} strokeWidth={2.2} />
          {site.phone}
        </a>
        <a href="/contact" class="btn btn-ink btn-sm hidden md:inline-flex">
          Book now
          <Icon name="ArrowRight" size={14} strokeWidth={2.4} />
        </a>

        <button id="menu-toggle" class="lg:hidden inline-flex items-center justify-center w-10 h-10 rounded-full transition self-center" style="color: #111113;" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
          <span class="hamburger" aria-hidden="true"><span></span><span></span><span></span></span>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden mt-2 mx-4 rounded-3xl overflow-hidden" style="background: rgba(255,255,255,0.98); backdrop-filter: blur(22px); border: 1px solid rgba(17,17,19,0.08); box-shadow: 0 30px 60px -20px rgba(17,17,19,0.3);">
    <nav class="flex flex-col p-4 max-h-[calc(100vh-7rem)] overflow-y-auto" aria-label="Mobile">
      {nav.map((item) => (
        <Fragment>
          <a href={item.href} class="py-3 px-2 text-ink/85 hover:text-ink border-b border-ink/10 font-display font-semibold transition" style={current === item.href ? 'color:#111113;font-weight:800' : ''}>{item.label}</a>
          {item.children && (
            <div class="flex flex-col pl-4 border-b border-ink/10">
              {item.children.filter((c) => c.href !== item.href).map((c) => (
                <a href={c.href} class="py-2.5 px-2 text-sm text-muted hover:text-ink transition">{c.label}</a>
              ))}
            </div>
          )}
        </Fragment>
      ))}
      <div class="grid grid-cols-2 gap-2 mt-4">
        <a href={telLink} class="btn btn-outline btn-sm">
          <Icon name="Phone" size={14} strokeWidth={2.2} /> Call us
        </a>
        <a href="/contact" class="btn btn-ink btn-sm">
          Book now
        </a>
      </div>
    </nav>
  </div>
</header>

<style>
  .hamburger { display: inline-flex; flex-direction: column; justify-content: center; gap: 4px; width: 22px; height: 22px; }
  .hamburger span { display: block; width: 22px; height: 2px; background: #111113; border-radius: 2px; transition: transform 0.4s cubic-bezier(0.68,-0.55,0.27,1.55), opacity 0.25s ease; transform-origin: center; }
  .hamburger.open span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.open span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

  /* Services-Dropdown */
  .nav-dd-panel {
    position: absolute; top: calc(100% + 10px); left: 50%; transform: translateX(-50%) translateY(8px);
    min-width: 220px; padding: 0.5rem; border-radius: 18px;
    background: rgba(255,255,255,0.97); border: 1px solid rgba(17,17,19,0.08);
    backdrop-filter: blur(22px) saturate(170%); -webkit-backdrop-filter: blur(22px) saturate(170%);
    box-shadow: 0 20px 44px -16px rgba(17,17,19,0.26), inset 0 1px 0 0 rgba(255,255,255,0.7);
    opacity: 0; visibility: hidden; transition: opacity 0.25s ease, transform 0.25s ease;
    z-index: 60;
  }
  /* unsichtbare Brücke über den 10px-Spalt — Hover reißt nicht ab */
  .nav-dd-panel::before { content: ""; position: absolute; left: 0; right: 0; top: -14px; height: 16px; }
  .nav-dd:hover .nav-dd-panel,
  .nav-dd:focus-within .nav-dd-panel { opacity: 1; visibility: visible; transform: translateX(-50%) translateY(0); }
  .nav-dd:hover .nav-dd-chev { transform: rotate(180deg); }
  .nav-dd-item {
    display: block; padding: 0.6rem 0.85rem; border-radius: 11px; font-size: 0.9rem; font-weight: 600;
    font-family: var(--font-display);
    color: rgba(17,17,19,0.72); transition: background 0.2s ease, color 0.2s ease;
  }
  .nav-dd-item:hover { background: rgba(17,17,19,0.06); color: #111113; }
  .nav-dd-item.active { color: #111113; background: rgba(17,17,19,0.05); font-weight: 700; }
  .nav-dd-chev { transition: transform 0.3s ease; }
</style>

<!-- is:inline: Menü-Toggle hängt ab Parse-Zeit (erster Tap funktioniert immer) -->
<script is:inline>
  (function () {
    var toggle = document.getElementById('menu-toggle');
    var menu = document.getElementById('mobile-menu');
    var shell = document.getElementById('nav-shell');
    var header = document.getElementById('site-header');
    var burger = toggle ? toggle.querySelector('.hamburger') : null;

    function isOpen() { return menu && !menu.classList.contains('hidden'); }
    function setOpen(open) {
      if (!menu) return;
      menu.classList.toggle('hidden', !open);
      if (burger) burger.classList.toggle('open', open);
      if (toggle) {
        toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
        toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      }
      document.body.style.overflow = open ? 'hidden' : '';
    }

    if (toggle) {
      toggle.addEventListener('click', function (e) { e.stopPropagation(); setOpen(!isOpen()); });
    }
    if (menu) {
      menu.querySelectorAll('a').forEach(function (a) {
        a.addEventListener('click', function () { setOpen(false); });
      });
    }
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && isOpen()) setOpen(false); });
    document.addEventListener('click', function (e) { if (isOpen() && header && !header.contains(e.target)) setOpen(false); });
    window.addEventListener('resize', function () { if (window.innerWidth >= 1024 && isOpen()) setOpen(false); });

    // Nav verstärken beim Scrollen
    var ticking = false;
    window.addEventListener('scroll', function () {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(function () {
        var y = window.scrollY;
        if (shell) {
          if (y > 30) { shell.style.background = 'rgba(255,255,255,0.94)'; shell.style.transform = 'scale(0.985)'; }
          else { shell.style.background = 'rgba(255,255,255,0.85)'; shell.style.transform = 'scale(1)'; }
        }
        ticking = false;
      });
    });
  })();
</script>
