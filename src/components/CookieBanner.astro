---
// Schlichte UK-Cookie-Notice (PECR). Die Site setzt keine Tracking-
// Cookies — Hinweis wird lokal (localStorage) gemerkt, mehr nicht.
---
<div id="cookie-banner" class="fixed bottom-0 left-0 right-0 z-[60] p-3 md:p-4 translate-y-full transition-transform duration-500" style="will-change: transform;">
  <div class="container-mk flex justify-start">
    <div class="rounded-2xl px-5 py-4 flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-5 max-w-xl" style="background: rgba(11,11,13,0.95); border: 1px solid rgba(255,255,255,0.12); box-shadow: 0 24px 60px -20px rgba(11,11,13,0.6); backdrop-filter: blur(14px);">
      <p class="text-white/70 text-[0.82rem] leading-relaxed">
        This site only uses essential cookies — no tracking, no analytics. See our
        <a href="/data-protection" class="text-white underline underline-offset-2">Data Protection</a> notice.
      </p>
      <button id="cookie-ok" class="btn btn-light btn-sm flex-shrink-0 self-start sm:self-auto">Got it</button>
    </div>
  </div>
</div>

<script>
  const KEY = 'mk-cookie-notice';
  document.addEventListener('astro:page-load', () => {
    const banner = document.getElementById('cookie-banner');
    const stored = (() => { try { return localStorage.getItem(KEY); } catch { return 'dismissed'; } })();
    if (!stored && banner) setTimeout(() => (banner.style.transform = 'translateY(0)'), 1400);
    document.getElementById('cookie-ok')?.addEventListener('click', () => {
      try { localStorage.setItem(KEY, 'ok'); } catch {}
      if (banner) banner.style.transform = 'translateY(150%)';
    });
  });
</script>
